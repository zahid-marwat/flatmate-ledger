PORT=3001

# Optional: set these for Supabase-backed persistence.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: if set, creating users from the admin panel requires this key.
ADMIN_SETUP_KEY=

# Optional fallback for immutable global admin users. Prefer users.app_role='admin' in the database.
GLOBAL_ADMIN_USER_IDS=

# Security limits.
MAX_REQUEST_BODY_BYTES=1000000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=30
